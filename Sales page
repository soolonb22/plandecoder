<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plan Decoder • Choose Your Plan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        body { font-family: 'Inter', system_ui, sans-serif; }
        .pricing-card {
            transition: all 0.2s ease;
        }
        .pricing-card.recommended {
            border-color: #0F766E;
            box-shadow: 0 10px 15px -3px rgb(15 118 110 / 0.1);
        }
        .price-btn {
            transition: all 0.15s ease;
        }
        .price-btn:hover {
            transform: translateY(-1px);
        }
        .price-btn.recommended {
            background-color: #0F766E;
            color: white;
            border-color: #0F766E;
        }
    </style>
</head>
<body class="bg-slate-50">

    <!-- Header -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
            <div class="flex items-center gap-x-3">
                <div class="w-9 h-9 bg-teal-800 rounded-xl flex items-center justify-center">
                    <span class="text-white font-bold text-xl">PD</span>
                </div>
                <span class="font-semibold text-xl tracking-tight">Plan Decoder</span>
            </div>
            <div class="text-sm text-slate-500 flex items-center gap-x-2">
                <i class="fa-solid fa-shield-halved text-emerald-600"></i>
                <span>100% Private • Browser Only</span>
            </div>
        </div>
    </header>

    <!-- Hero -->
    <div class="max-w-4xl mx-auto px-6 pt-12 pb-8 text-center">
        <div class="inline-block px-4 py-1 bg-teal-100 text-teal-700 rounded-full text-sm font-medium mb-4">
            For NDIS Participants
        </div>
        <h1 class="text-4xl md:text-5xl font-semibold tracking-tighter text-slate-900 leading-tight">
            Choose the plan and price<br>that works for you
        </h1>
        <p class="mt-4 text-lg text-slate-600 max-w-lg mx-auto">
            All tools run privately in your browser. Nothing is stored or sent anywhere.
        </p>
    </div>

    <!-- Pricing Section -->
    <div class="max-w-6xl mx-auto px-6 pb-16">
        <div class="grid md:grid-cols-3 gap-6">
            
            <!-- Tier 1: Essential -->
            <div class="pricing-card bg-white border border-slate-200 rounded-3xl p-6 flex flex-col">
                <div class="mb-4">
                    <div class="font-semibold text-lg">Essential</div>
                    <div class="text-sm text-slate-500 mt-1">Language Translator + Informal Support Calculator</div>
                </div>

                <div class="mt-auto">
                    <div class="text-sm font-medium text-slate-600 mb-2">Choose your price:</div>
                    
                    <div class="grid grid-cols-3 gap-2">
                        <button onclick="selectPlan('Essential', 27)"
                                class="price-btn px-3 py-2.5 text-sm border border-slate-300 hover:border-teal-600 rounded-2xl font-semibold">
                            $27
                        </button>
                        <button onclick="selectPlan('Essential', 47)"
                                class="price-btn px-3 py-2.5 text-sm border border-teal-700 bg-teal-50 text-teal-700 hover:bg-teal-100 rounded-2xl font-semibold recommended">
                            $47
                        </button>
                        <button onclick="selectPlan('Essential', 67)"
                                class="price-btn px-3 py-2.5 text-sm border border-slate-300 hover:border-teal-600 rounded-2xl font-semibold">
                            $67
                        </button>
                    </div>
                    <div class="text-[10px] text-center text-slate-400 mt-1.5">$47 is the standard rate</div>
                </div>
            </div>

            <!-- Tier 2: Essential + Fluctuation Patterns (Recommended) -->
            <div class="pricing-card recommended bg-white border-2 border-teal-700 rounded-3xl p-6 flex flex-col relative">
                <div class="absolute -top-3 right-6 bg-teal-700 text-white text-xs font-bold px-4 py-1 rounded-full">
                    Most Popular
                </div>
                
                <div class="mb-4">
                    <div class="font-semibold text-lg text-teal-700">Essential + Fluctuation Patterns</div>
                    <div class="text-sm text-slate-500 mt-1">Everything in Essential + Advanced Fluctuation Patterns</div>
                </div>

                <div class="mt-auto">
                    <div class="text-sm font-medium text-slate-600 mb-2">Choose your price:</div>
                    
                    <div class="grid grid-cols-3 gap-2">
                        <button onclick="selectPlan('Essential + Fluctuation', 57)"
                                class="price-btn px-3 py-2.5 text-sm border border-slate-300 hover:border-teal-600 rounded-2xl font-semibold">
                            $57
                        </button>
                        <button onclick="selectPlan('Essential + Fluctuation', 77)"
                                class="price-btn px-3 py-2.5 text-sm border border-teal-700 bg-teal-600 text-white hover:bg-teal-700 rounded-2xl font-semibold">
                            $77
                        </button>
                        <button onclick="selectPlan('Essential + Fluctuation', 97)"
                                class="price-btn px-3 py-2.5 text-sm border border-slate-300 hover:border-teal-600 rounded-2xl font-semibold">
                            $97
                        </button>
                    </div>
                    <div class="text-[10px] text-center text-slate-400 mt-1.5">$77 is the standard rate</div>
                </div>
            </div>

            <!-- Tier 3: Pro Suite -->
            <div class="pricing-card bg-white border border-slate-200 rounded-3xl p-6 flex flex-col">
                <div class="mb-4">
                    <div class="font-semibold text-lg">Pro Suite</div>
                    <div class="text-sm text-slate-500 mt-1">Everything + s34 Builder + Meeting Prep Pack</div>
                </div>

                <div class="mt-auto">
                    <div class="text-sm font-medium text-slate-600 mb-2">Choose your price:</div>
                    
                    <div class="grid grid-cols-3 gap-2">
                        <button onclick="selectPlan('Pro Suite', 97)"
                                class="price-btn px-3 py-2.5 text-sm border border-slate-300 hover:border-teal-600 rounded-2xl font-semibold">
                            $97
                        </button>
                        <button onclick="selectPlan('Pro Suite', 127)"
                                class="price-btn px-3 py-2.5 text-sm border border-teal-700 bg-teal-50 text-teal-700 hover:bg-teal-100 rounded-2xl font-semibold recommended">
                            $127
                        </button>
                        <button onclick="selectPlan('Pro Suite', 157)"
                                class="price-btn px-3 py-2.5 text-sm border border-slate-300 hover:border-teal-600 rounded-2xl font-semibold">
                            $157
                        </button>
                    </div>
                    <div class="text-[10px] text-center text-slate-400 mt-1.5">$127 is the standard rate</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Comparison -->
    <div class="max-w-5xl mx-auto px-6 pb-16">
        <h3 class="text-center font-semibold mb-6">Quick Comparison</h3>
        <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden text-sm">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="text-left p-4 font-medium">Feature</th>
                        <th class="text-center p-4 font-medium">Essential</th>
                        <th class="text-center p-4 font-medium bg-teal-50">Essential + Fluctuation</th>
                        <th class="text-center p-4 font-medium">Pro Suite</th>
                    </tr>
                </thead>
                <tbody class="divide-y text-center">
                    <tr>
                        <td class="p-4 text-left">Language Translator</td>
                        <td>✓</td>
                        <td>✓</td>
                        <td>✓</td>
                    </tr>
                    <tr>
                        <td class="p-4 text-left">Informal Support Calculator</td>
                        <td>✓</td>
                        <td>✓</td>
                        <td>✓</td>
                    </tr>
                    <tr>
                        <td class="p-4 text-left">Advanced Fluctuation Patterns</td>
                        <td class="text-slate-400">Basic</td>
                        <td>✓</td>
                        <td>✓</td>
                    </tr>
                    <tr>
                        <td class="p-4 text-left">s34 Builder</td>
                        <td class="text-slate-400">—</td>
                        <td class="text-slate-400">—</td>
                        <td>✓</td>
                    </tr>
                    <tr>
                        <td class="p-4 text-left">Professional PDF Reports</td>
                        <td class="text-slate-400">—</td>
                        <td>Basic</td>
                        <td>Full</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Why Sliding Scale -->
    <div class="max-w-2xl mx-auto px-6 pb-12 text-center">
        <div class="bg-white border border-slate-200 rounded-3xl p-6 text-sm">
            <p class="text-slate-600">
                We offer different prices because many NDIS participants are on low income or managing significant costs. 
                Please choose the option that feels honest for your situation right now. No questions asked.
            </p>
        </div>
    </div>

    <!-- Disclaimer -->
    <div class="max-w-3xl mx-auto px-6 pb-12">
        <div class="text-xs text-slate-500 border border-slate-200 bg-white rounded-2xl p-5">
            <strong>Important:</strong> Plan Decoder is a preparation and organisation tool only. It helps you organise your own information. 
            It does not provide legal, medical, or financial advice and does not guarantee any NDIS funding outcomes. 
            All decisions are made by the NDIA. Please review outputs with a support coordinator or trusted professional.
        </div>
    </div>

    <footer class="text-center text-xs text-slate-400 pb-8">
        Plan Decoder • Not affiliated with the NDIA
    </footer>

    <script>
        function selectPlan(planName, price) {
            const message = `Thank you!\n\n` +
                           `You selected: ${planName}\n` +
                           `Price: $${price}\n\n` +
                           `In the live version, this would take you to secure checkout.\n\n` +
                           `Would you like me to create the Stripe checkout version next?`;
            
            alert(message);
            
            // Example of how you would redirect in production:
            // window.location.href = `https://buy.stripe.com/...`;
        }
    </script>
</body>
</html>
